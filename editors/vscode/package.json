{
  "name": "kozue-vscode",
  "displayName": "kozue",
  "description": "Kozue diagram language support (LSP diagnostics)",
  "version": "0.1.0",
  "publisher": "kozue",
  "engines": { "vscode": "^1.82.0" },
  "categories": ["Programming Languages"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kozue",
        "aliases": ["Kozue", "kozue"],
        "extensions": [".kozue", ".kzd"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "mermaid",
        "aliases": ["Mermaid"],
        "extensions": [".mmd", ".mermaid"]
      },
      {
        "id": "plantuml",
        "aliases": ["PlantUML"],
        "extensions": [".puml", ".plantuml", ".pu", ".iuml"]
      }
    ],
    "configuration": {
      "title": "Kozue",
      "properties": {
        "kozue.serverPath": {
          "type": "string",
          "default": "kozue-lsp",
          "description": "Path to the kozue-lsp binary. Defaults to `kozue-lsp` on PATH."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.82.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  }
}
